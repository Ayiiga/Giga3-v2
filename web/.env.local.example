# Copy to web/.env.local for local development / production build tests.
# Convention: NEXT_PUBLIC_* only (Next.js inlines these at build time).

# Required — from Convex dashboard → Deployment URL
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud

# Optional — HTTP actions / .convex.site URL
NEXT_PUBLIC_CONVEX_SITE_URL=https://your-deployment.convex.site

# Paystack public key — enables Inline popup checkout (also readable from Convex PAYSTACK_PUBLIC_KEY)
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_live_your_public_key
