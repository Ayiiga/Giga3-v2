# Copy to web/.env.local for local dev (not committed).
# Production values are set as GitHub Actions secrets for CI builds.

# Required — from Convex dashboard → Deployment URL (*.convex.cloud)
NEXT_PUBLIC_CONVEX_URL=http://127.0.0.1:3210

# Optional — HTTP actions URL (*.convex.site)
NEXT_PUBLIC_CONVEX_SITE_URL=http://127.0.0.1:3211

# OpenAI and Paystack secrets belong on Convex (npx convex env set), not here.
