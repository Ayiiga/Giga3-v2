# Copy to web/.env.local for local development.

# Required at build time for production (also set in GitHub Actions secrets)
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud
NEXT_PUBLIC_CONVEX_SITE_URL=https://your-deployment.convex.site

# Optional — Paystack public key (checkout uses Convex actions; secret stays on Convex)
# NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=
